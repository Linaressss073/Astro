{
    "projects": [
      {
        "name": "frontend",
        "src": "frontend/",
        "buildCommand": "npm install && npm run build",
        "outputDirectory": "dist"
      },
      {
        "name": "backend",
        "src": "backend/",
        "buildCommand": "npm install",
        "outputDirectory": "."
      }
    ],
    "routes": [
      { "src": "/api/(.*)", "dest": "/backend/index.js" },
      { "src": "(.*)", "dest": "/frontend/$1" }
    ]
  }
  